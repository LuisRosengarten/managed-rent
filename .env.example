# ====================================================================
# Database (Neon serverless postgres or any standard Postgres URL)
# ====================================================================
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ====================================================================
# App encryption — generate via: openssl rand -base64 32
# ====================================================================
APP_ENCRYPTION_KEY=

# ====================================================================
# better-auth — generate via: openssl rand -hex 32
# ====================================================================
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ====================================================================
# Uploadthing — create app at https://uploadthing.com, copy token
# ====================================================================
UPLOADTHING_TOKEN=

# ====================================================================
# Google OAuth — for Gmail integration
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI must match GOOGLE_REDIRECT_URI exactly
# Scopes: gmail.readonly, gmail.send, userinfo.email, openid
# ====================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# ====================================================================
# Microsoft OAuth — for Outlook / Microsoft 365
# Console: https://portal.azure.com → App registrations
# Redirect URI must match MICROSOFT_REDIRECT_URI exactly
# Scopes: offline_access Mail.Read Mail.Send User.Read
# ====================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/oauth/microsoft/callback

# ====================================================================
# Optional: default AI provider when user hasn't set one as primary
# anthropic | openai | google
# ====================================================================
DEFAULT_AI_PROVIDER=anthropic
